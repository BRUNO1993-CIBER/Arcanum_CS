<Window x:Class="Arcanum.UI.ChangePasswordWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Trocar Senha Mestre" Icon="avares://Arcanum/Assets/ico.ico"
        Height="500" Width="560"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        Background="{StaticResource BgBrush}">

    <Grid>
        <Border Background="{StaticResource CardBrush}" CornerRadius="12" Margin="60,40">
            <StackPanel Margin="40,24">

                <TextBlock Text="Trocar Senha Mestre" FontSize="20" FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <Border Background="#3A3A3C" Height="1" Margin="0,16"/>

                <TextBlock Text="Senha atual" Margin="0,0,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PbOld" PasswordChar="•"
                             FontFamily="Consolas,Cascadia Code,DejaVu Sans Mono,monospace"/>
                    <Button Grid.Column="1" x:Name="BtnShowOld" Content="👁"
                            Width="40" Height="36" Margin="4,0,0,0"
                            Classes="Secondary"
                            Click="OnToggleOld"/>
                </Grid>

                <TextBlock Text="Nova senha" Margin="0,14,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PbNew" PasswordChar="•"
                             FontFamily="Consolas,Cascadia Code,DejaVu Sans Mono,monospace"
                             TextChanged="OnPasswordChanged"/>
                    <Button Grid.Column="1" x:Name="BtnShowNew" Content="👁"
                            Width="40" Height="36" Margin="4,0,0,0"
                            Classes="Secondary"
                            Click="OnToggleNew"/>
                </Grid>

                <TextBlock Text="Confirmar nova senha" Margin="0,14,0,4"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PbConfirm" PasswordChar="•"
                             FontFamily="Consolas,Cascadia Code,DejaVu Sans Mono,monospace"
                             TextChanged="OnPasswordChanged"/>
                    <Button Grid.Column="1" x:Name="BtnShowConfirm" Content="👁"
                            Width="40" Height="36" Margin="4,0,0,0"
                            Classes="Secondary"
                            Click="OnToggleConfirm"/>
                </Grid>

                <TextBlock x:Name="TbStatus" FontSize="11" TextWrapping="Wrap"
                           Foreground="{StaticResource SubtleBrush}"
                           Margin="0,8,0,0"/>

                <Border Background="#3A3A3C" Height="1" Margin="0,16"/>

                <Button Content="Confirmar troca" Height="40" Width="200"
                        HorizontalAlignment="Center"
                        Classes="Success"
                        Click="OnSubmit"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>
